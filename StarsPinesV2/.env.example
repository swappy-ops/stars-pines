# Stars & Pines V2 — Environment Configuration
# Copy this file to .env and fill in values.

# Database
SP_DB_PATH=./sp_v2.db

# Server
SP_HOST=0.0.0.0
SP_PORT=8000
SP_ENV=development

# Assets
SP_ASSETS_DIR=./assets

# Backups
SP_BACKUP_DIR=./backups
SP_BACKUP_SCHEDULE=02:00

# WhatsApp (for notifications — Phase 10)
SP_WHATSAPP_NUMBER=
SP_WHATSAPP_API_KEY=

# Admin PIN (first staff account seed)
SP_ADMIN_PIN=
